# Bot API URLs (use direct IP:port for Wispbyte servers)
AI_BOT_URL=your_ai_bot_url:port
MUSIC_BOT_URL=your_music_bot_url:port

# Dashboard server port
PORT=80

# Admin password (leave empty to disable login)
ADMIN_PASSWORD=admin_password_here

# Auto-refresh interval in seconds
REFRESH_INTERVAL=10

# Bot invite links (optional)
#AI_INVITE=https://discord.com/api/oauth2/authorize?client_id=YOUR_AI_CLIENT_ID&permissions=0&scope=bot
#MUSIC_INVITE=https://discord.com/api/oauth2/authorize?client_id=YOUR_MUSIC_CLIENT_ID&permissions=0&scope=bot

# Session secret (auto-generated if not set)
#SESSION_SECRET=your_random_secret_here
